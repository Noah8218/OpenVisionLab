        private bool SetHomeResult(uint uHomeResult, bool bLogDisplay)
        {
            try
            {
                string strReason = "";
                uint uRet = 0;
                uRet = CAXM.AxmHomeSetResult(m_nAxisNo, uHomeResult);

                if (uRet != 0)
                {
                    strReason = GetReturnCode(uRet);
                    CLogger.WriteLog(LOG.MOTION, "[Failed] --> {0}", strReason);
                    return false;
                }
                else
                {
                    return DecodeHomeResult(uHomeResult, out string strResult);
                }

                if (bLogDisplay)
                {
                    CLogger.WriteLog(LOG.MOTION, "[Result] --> {0}", uHomeResult);
                    CLogger.WriteLog(LOG.MOTION, "[OK] {0}==>{1}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name);
                }

                return true;
            }
            catch (Exception Desc)
            {
                CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
                return false;
            }
        }

        public bool DecodeHomeResult(uint uHomeResult, out string strResult)
        {
            strResult = "EMPTY";

            try
            {
                switch (uHomeResult)
                {
                    case (uint)AXT_MOTION_HOME_RESULT.HOME_SUCCESS:
                        strResult = ("[01H] HOME_SUCCESS");
                        return true;
                    case (uint)AXT_MOTION_HOME_RESULT.HOME_SEARCHING: strResult = ("([02H] HOME_SEARCHING"); break;
                    case (uint)AXT_MOTION_HOME_RESULT.HOME_ERR_GNT_RANGE: strResult = ("[10H] HOME_ERR_GNT_RANGE"); break;
                    case (uint)AXT_MOTION_HOME_RESULT.HOME_ERR_USER_BREAK: strResult = ("[11H] HOME_ERR_USER_BREAK"); break;
                    case (uint)AXT_MOTION_HOME_RESULT.HOME_ERR_VELOCITY: strResult = ("[12H] HOME_ERR_VELOCITY"); break;
                    case (uint)AXT_MOTION_HOME_RESULT.HOME_ERR_AMP_FAULT: strResult = ("[13H] HOME_ERR_AMP_FAULT"); break;
                    case (uint)AXT_MOTION_HOME_RESULT.HOME_ERR_NEG_LIMIT: strResult = ("[14H] HOME_ERR_NEG_LIMIT"); break;
                    case (uint)AXT_MOTION_HOME_RESULT.HOME_ERR_POS_LIMIT: strResult = ("[15H] HOME_ERR_POS_LIMIT"); break;
                    case (uint)AXT_MOTION_HOME_RESULT.HOME_ERR_NOT_DETECT: strResult = ("[16H] HOME_ERR_NOT_DETECT"); break;
                    case (uint)AXT_MOTION_HOME_RESULT.HOME_ERR_UNKNOWN: strResult = ("[FFH] HOME_ERR_UNKNOWN"); break;
                }

                return false;
            }
            catch (Exception Desc)
            {
                CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
                return false;
            }
        }
        #endregion

    }


    public class IMotionStatus
    {
        // Z상
        private uint m_uZPhaseLevel = 0;
        public uint ZPhaseLevel
        {
            get { return m_uZPhaseLevel; }
            set { m_uZPhaseLevel = value; }
        }

        private bool m_bServoAlarm = false;
        public bool ServoAlarm
        {
            get { return m_bServoAlarm; }
            set { m_bServoAlarm = value; }
        }

        public bool m_bInposition = false;
        public bool Inposition
        {
            get => m_bInposition;
            set => m_bInposition = value;
        }
        private bool m_bEMS = false;
        public bool EMS
        {
            get { return m_bEMS; }
            set { m_bEMS = value; }
        }
        private bool m_bPlusLimit = false;
        public bool PlusLimit
        {
            get { return m_bPlusLimit; }
            set { m_bPlusLimit = value; }
        }
        private bool m_bMinusLimit = false;
        public bool MinusLimit
        {
            get { return m_bMinusLimit; }
            set { m_bMinusLimit = value; }
        }

        private uint m_uSoftPositiveLimit = 0;
        public uint SoftPositiveLimit
        {
            get { return m_uSoftPositiveLimit; }
            set { m_uSoftPositiveLimit = value; }
        }
        private uint m_uSoftSoftNegativeLimit = 0;
        public uint SoftNegativeLimit
        {
            get { return m_uSoftSoftNegativeLimit; }
            set { m_uSoftSoftNegativeLimit = value; }
        }
        /* 
         - INPUT
         0 : 원점 신호
         1 : Encoder Z상 신호
         2~4 : 범용 입력 신호
         5 : 범용 입력(SMC-2V04)

        - OUTPUT
        0 : 서보 On/Off 신호 
        1 : 알람 제거 신호
        2~4 : 범용 출력
        5 : 범용 출력(SMC-2V04)

        */
        private bool m_bHomeSensor = false;
        public bool HomeSensor
        {
