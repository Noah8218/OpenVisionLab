        #region HOME
        private CThreadStatus ThreadStatusHome { get; set; } = new CThreadStatus();

        public void StartThreadHome()
        {
            Thread t = new Thread(new ParameterizedThreadStart(ThreadHome));
            t.Start(ThreadStatusHome);
        }

        public void StopThreadHome()
        {
            if (!ThreadStatusHome.IsExit())
            {
                ThreadStatusHome.Stop(100);
            }

            StopMoveStop();
        }

        //int m_nAliveTime = 0;
        private void ThreadHome(object ob)
        {
            CThreadStatus ThreadStatus = (CThreadStatus)ob;

            ThreadStatus.Start(AxisName + " Home Start");
            CLogger.WriteLog(LOG.MOTION, AxisName + " Home Start");

            try
            {
                int nStartTime = Environment.TickCount;
                int TIME_OUT = 120000;

                StartHome();

                while (!ThreadStatus.IsExit())
                {
                    Thread.Sleep(1);

                    try
                    {
                        uint uHomeReslt = 0;
                        
                        if(GetHomeResult(ref uHomeReslt, true))
                        {
                            m_bIsHomeComplete = true;
                            break;
                        }
                        else
                        {
                            if(Environment.TickCount - nStartTime > TIME_OUT)
                            {
                                CLogger.WriteLog(LOG.MOTION, "[Fail] Home Failed");
                                break;
                            }
                        }
                    }
                    catch (Exception Desc)
                    {
                        CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
                    }
                }

                ThreadStatus.End();
            }
            catch (Exception Desc)
            {
                CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
            }

        }

        /// <summary>
        /// 원점 검색을 시작합니다. 함수가 실행되면 라이브러리 내부에서 해당 축의 원점 검색을 수행할 스레드가 자동 생성되어 원점 검색을 순차적으로 수행한 후 자동 종료됩니다.
        /// </summary>
        /// <param name="nAxis"></param>
        /// <returns></returns>
        public bool StartHome()
        {
            try
            {
                // ++ =======================================================================
                // >> OnBtnHomeStart() : "Home Start"버튼 클릭시 호출되는 핸들러 함수.
                //  - 선택한 축으로 원점검색을 진행합니다.
                //  - 원점검색의 단계를 세분화해 빠르고 정밀하게 원점검색을 구현할 수 있습니다.
                // ※ [CAUTION] 원점검색시 라이브러리 내부에서 해당축의 원점검색을 수행 할 쓰레드가
                //    자동 생성되어 원점검색을 순차적으로 수행한 후 자동 종료됩니다. 따라서 단일 
                //    CPU시스템의 경우 사용자 프로그램에서 CPU를 100% 점유할 경우 원점 검색 진행이
                //    원할하게 되지 않을 수 있습니다.
                // --------------------------------------------------------------------------
                m_bIsHomeComplete = false;

                string strReason = "";
                /*uint uRet = 4053;   // 초기화실패 메세지
                if (m_nAxisNo != 2)
                {
                    uint uHomeResult = 0;
                    CAXM.AxmHomeGetResult(2, ref uHomeResult);

                    if (uHomeResult == 0)
                        uRet = CAXM.AxmHomeSetStart(m_nAxisNo);
                }
                else*/
                uint uRet = CAXM.AxmHomeSetStart(m_nAxisNo);

                if (uRet != 0)
                {
                    strReason = GetReturnCode(uRet);
                    CLogger.WriteLog(LOG.MOTION, "[Failed] --> {0}", strReason);
                    return false;
                }

                CLogger.WriteLog(LOG.MOTION, "[OK] {0}==>{1}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name);
                return true;
            }
            catch (Exception Desc)
            {
                CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
                return false;
            }
        }


