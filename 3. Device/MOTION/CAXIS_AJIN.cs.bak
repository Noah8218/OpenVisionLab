        /// <summary>
        /// 지정 축의 이동 거리 계산 모드를 설정합니다.
        /// </summary>
        /// <param name="nAxis"></param>
        /// <param name="uAbsRelMode"></param>
        /// <returns></returns>
        public bool SetMoveMode(uint uAbsRelMode)
        {
            try
            {
                // 0: 절대 모드 --> 예를 들어 현재 위치값 이 10 일 때 절대 위치 모드에서 100 위치로 이동할 경우 현재 위치에서 ‘‘+90 만큼 이동하여 100 위치에서 정지하게 된다
                // 1: 상대 모드 --> 예를 들어 현재 위치값 이 10 일 때 상대 위치 모드에서 100 만큼 이동할 경우 ,현재 위치에서 ‘‘+100 만큼 이동하여 110 의 위치에서 정지하게 된다
                string strReason = "";
                uint uRet = 0;
                uRet = CAXM.AxmMotSetAbsRelMode(m_nAxisNo, uAbsRelMode);

                if (uRet != 0)
                {
                    strReason = GetReturnCode(uRet);
                    CLogger.WriteLog(LOG.MOTION, "[Fail] --> {0}", strReason);
                    return false;
                }

                CLogger.WriteLog(LOG.MOTION, "[OK] {0}==>{1}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name);
                return true;
            }
            catch (Exception Desc)
            {
                CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
                return false;
            }
        }

