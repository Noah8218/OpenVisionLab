        #region Thread
        private CThreadStatus ThreadStatusReadStatus {get;set;} = new CThreadStatus();
        private void StartThreadReadStatus()
        {
            if(ThreadStatusReadStatus.IsExit())
            {
                Thread t = new Thread(new ParameterizedThreadStart(ThreadReadStatus));
                t.Start(ThreadStatusReadStatus);
            }
        }
        public void StopThreadReadStatus()
        {
            if (!ThreadStatusReadStatus.IsExit())
            {
                ThreadStatusReadStatus.Stop(100);
            }
        }
        private void ThreadReadStatus(object ob)
        {
            CThreadStatus ThreadStatus = (CThreadStatus)ob;

            ThreadStatus.Start("Status Read");

            try
            {
                while (!ThreadStatus.IsExit())
                {
                    Thread.Sleep(1);

                    try
                    {
                        bool bSuccess = false;
                        // 0과 1중 둘 중 한개의 값을 가져오기에 다른값으로 처음에 초기화
                        uint uStatus1 = 100;
                        uint uStatus2 = 100;
                        double dPosition = 0;
                        double dVelocity = 0;

                        //++ Servo Alarm 신호의 상태를 확인합니다.
                        bSuccess = ReadServoAlarm(ref uStatus1);
                        Status.ServoAlarm = uStatus1 > 0;

                        //++ Inposition(위치결정완료) 신호의 상태를 확인합니다.
                        //bSuccess = ReadInposition(AxisNo, ref uStatus1);                        

                        //++ Emergency 신호의 상태를 확인합니다.
                        bSuccess = ReadEMGStop(AxisNo, ref uStatus1);
                        Status.EMS = uStatus1 > 0;

                        //++ (+/-)End Limit신호의 상태를 확인합니다.
                        bSuccess = ReadLimit(ref uStatus1, ref uStatus2);
                        Status.PlusLimit = uStatus1 > 0; ;
                        Status.MinusLimit = uStatus2 > 0; ;                        

                        for (uint uBitNo = 0; uBitNo < (uint)AXT_MOTION_UNIV_OUTPUT.UIO_OUT2; uBitNo++)
                        {
                            //++ 범용입력 신호의(Bit00-Bit04) 상태를 확인합니다.
                            bSuccess = ReadSignalInputBit(AxisNo, (int)uBitNo, ref uStatus1);
                            //++ 범용출력 신호의(Bit00-Bit04) 상태를 확인합니다.
                            bSuccess = ReadSignalOutputBit(AxisNo, (int)uBitNo, ref uStatus2);

                            switch (uBitNo)
                            {
                                case 0:
                                    Status.HomeSensor = uStatus1 > 0; ;
                                    Status.ServoOn = uStatus2 > 0; ;
                                    break;
                                case 1:
                                    Status.OutputAlarmClear = uStatus2;
                                    break;
                            }
                        }

                        // 실제 위치
                        bSuccess = GetPulseCount(AxisNo, ref dPosition);
                        Status.ActualPos = dPosition;
                        m_lActualPos = (long)dPosition;

                        // 지령 위치
                        bSuccess = GetComPulseCount(AxisNo, ref dPosition);
                        Status.CommandPos = dPosition;

                        // 지령 위치 - 실제 위치
                        bSuccess = GetActToComdDifferenceInValue(AxisNo, ref dPosition);
                        Status.ActToComdDifferenceInValue = dPosition;
                        
                        // 모션 구동 여부
                        bSuccess = GetStatusInMotion(AxisNo, ref uStatus1);
                        Status.InMotion = uStatus1>0;

                        //인포지션
                        bSuccess = GetInposition(ref uStatus1);
                        Status.Inposition = uStatus1 > 0;

                        // 현재 축의 속도
                        bSuccess = GetStatusReadVel(AxisNo, ref dVelocity);
                        Status.VelocityCurrent = dVelocity;

                        // 홈 레벨 상태 확인
                        bSuccess = ReadSignalHome(AxisNo, ref uStatus1);
                        Home.HomeStatus = uStatus1;

                        // 홈 상태 확인
                        bSuccess = GetHomeResult(ref uStatus1, false);
                        Home.HomeInProgress = uStatus1;

                        uint uHomeRate = 0;

                        bSuccess = GetHomeRate(ref uHomeRate);

                        HomeRate = (int)uHomeRate;

                        if (!bSuccess)
                        {
                            // 예외처리
                        }
                    }
                    catch (Exception Desc)
                    {
                        CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
                    }
                }
            }
            catch (Exception Desc)
            {
                CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
            }

        }
        #endregion

        public bool Init()
        {
            try
            {
                uint nModuleID = 0;
                int nBoardNo = 0;
                int nBoardPos = 0;
                string strAxis = "";
                bool bResult = true;

                //if (m_bUseMotFile)
                //{
                //    //20210118_SWT.mot
                //    string strMotFilePath = Application.StartupPath + "20210118_SWT.mot";
                //    bResult = LoadMOTConfig(strMotFilePath);
                //}

                if (bResult)
                {
                    if (CAXM.AxmSignalSetStop(m_nAxisNo, (uint)AXT_MOTION_STOPMODE.EMERGENCY_STOP, (uint)AXT_MOTION_LEVEL_MODE.LOW) != (uint)AXT_FUNC_RESULT.AXT_RT_SUCCESS) return false;
                    CLogger.WriteLog(LOG.MOTION, "Complete to Open the Axis [{0}]", m_nAxisNo);

                    switch (m_nAxisNo)
                    {
                        case 0:
                            SetInputEncoderMode((int)CMOTION_AJIN.InputEncoderMode.ObverseSqr4Mode);
                            SetOutputEncoderMode((int)CMOTION_AJIN.OutputEncoderMode.TwoCwCcwLow);
                            break;
                        case 1:
                            SetInputEncoderMode((int)CMOTION_AJIN.InputEncoderMode.ReverseSqr4Mode);
                            SetOutputEncoderMode((int)CMOTION_AJIN.OutputEncoderMode.TwoCwCcwLow);
                            break;
                        case 2:
                            SetInputEncoderMode((int)CMOTION_AJIN.InputEncoderMode.ReverseSqr4Mode);
                            SetOutputEncoderMode((int)CMOTION_AJIN.OutputEncoderMode.TwoCwCcwHigh);
                            break;
                        case 3:
                            SetInputEncoderMode((int)CMOTION_AJIN.InputEncoderMode.ObverseSqr4Mode);
                            SetOutputEncoderMode((int)CMOTION_AJIN.OutputEncoderMode.TwoCwCcwLow);
                            break;
                        default:
                            SetInputEncoderMode((int)CMOTION_AJIN.InputEncoderMode.ObverseSqr4Mode);
                            SetOutputEncoderMode((int)CMOTION_AJIN.OutputEncoderMode.TwoCwCcwHigh);
                            break;
                    }


                    //SetSingleLimit(m_nAxisNo, (uint)MOTION_AJIN.Status_StopMode.SlowDownStop, (uint)MOTION_AJIN.Status_LevelMode.Low, (uint)MOTION_AJIN.Status_LevelMode.Low);


                    CAXM.AxmSignalServoOn(m_nAxisNo, 1);
                    CAXM.AxmInfoGetAxis(m_nAxisNo, ref nBoardNo, ref nBoardPos, ref nModuleID);
                    switch (nModuleID)
                    {
                        //++ 지정한 축의 정보를 반환합니다.
                        // [INFO] 여러개의 정보를 읽는 함수 사용시 불필요한 정보는 NULL(0)을 입력하면 됩니다.
                        case (uint)AXT_MODULE.AXT_SMC_4V04: strAxis = String.Format("{0:00}-[PCIB-QI4A]", m_nAxisNo); break;
                        case (uint)AXT_MODULE.AXT_SMC_2V04: strAxis = String.Format("{0:00}-[PCIB-QI2A]", m_nAxisNo); break;
                        case (uint)AXT_MODULE.AXT_SMC_R1V04: strAxis = String.Format("{0:00}-(RTEX-PM)", m_nAxisNo); break;
                        case (uint)AXT_MODULE.AXT_SMC_R1V04PM2Q: strAxis = String.Format("{0:00}-(RTEX-PM2Q)", m_nAxisNo); break;
                        case (uint)AXT_MODULE.AXT_SMC_R1V04PM2QE: strAxis = String.Format("{0:00}-(RTEX-PM2QE)", m_nAxisNo); break;
                        case (uint)AXT_MODULE.AXT_SMC_R1V04A4: strAxis = String.Format("{0:00}-[RTEX-A4N] : Not support", m_nAxisNo); break;
                        case (uint)AXT_MODULE.AXT_SMC_R1V04A5: strAxis = String.Format("{0:00}-[RTEX-A5N] : Not support", m_nAxisNo); break;
                        case (uint)AXT_MODULE.AXT_SMC_R1V04MLIISV: strAxis = String.Format("{0:00}-[MLII-SGDV] : Not support", m_nAxisNo); break;
                        case (uint)AXT_MODULE.AXT_SMC_R1V04MLIIPM: strAxis = String.Format("{0:00}-(MLII-PM) : Not support", m_nAxisNo); break;
                        case (uint)AXT_MODULE.AXT_SMC_R1V04MLIICL: strAxis = String.Format("{0:00}-[MLII-CSDL] : Not support", m_nAxisNo); break;
                        case (uint)AXT_MODULE.AXT_SMC_R1V04MLIICR: strAxis = String.Format("{0:00}-[MLII-CSDH] : Not support", m_nAxisNo); break;
                        case (uint)AXT_MODULE.AXT_SMC_R1V04SIIIHMIV: strAxis = String.Format("{0:00}-[SIIIH-MRJ4] : Not support", m_nAxisNo); break;
                        default: strAxis = String.Format("{0:00}-[Unknown] : Not support", m_nAxisNo); break;
                    }

                    InitContaceAorB();
                    InitHomeParameter();
                }

                if (m_nAxisNo == 0)
                {
                    TriggerSetTimeLevel(1000, 0, 1, 0);
                }

                StartThreadReadStatus();
                return true;
            }
            catch (Exception Desc)
            {
                CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
                return false;
            }
        }

        public bool InitContaceAorB()
        {
            try
            {
                uint uRetCode;
                uint uStopMode = 0, uPosigitaveLevel = 0, uNegativeLevel = 0;

                uRetCode = CAXM.AxmSignalGetLimit(m_nAxisNo, ref uStopMode, ref uPosigitaveLevel, ref uNegativeLevel);

                switch (m_nAxisNo)
                {                    
                    case 3:
                        if (uRetCode == (uint)AXT_FUNC_RESULT.AXT_RT_SUCCESS)
                        {
                            CAXM.AxmSignalSetLimit(m_nAxisNo, uStopMode, (uint)PARAM_LEVEL.HIGH, (uint)PARAM_LEVEL.LOW);
                        }
                        break;                   
                    default:
                        if (uRetCode == (uint)AXT_FUNC_RESULT.AXT_RT_SUCCESS)
                        {
                            CAXM.AxmSignalSetLimit(m_nAxisNo, uStopMode, (uint)PARAM_LEVEL.LOW, (uint)PARAM_LEVEL.LOW);
                        }
                        break;
                }

                CAXM.AxmMotSetAccelUnit(m_nAxisNo, 1);
                CAXM.AxmSignalSetInpos(m_nAxisNo, (uint)PARAM_LEVEL.HIGH);
                CAXM.AxmSignalSetStop(m_nAxisNo, uStopMode, (uint)PARAM_LEVEL.HIGH);
                CAXM.AxmSignalSetServoAlarmResetLevel(m_nAxisNo, (uint)PARAM_LEVEL.HIGH);
                CAXM.AxmHomeSetSignalLevel(m_nAxisNo, (uint)PARAM_LEVEL.HIGH);

                return true;
            }
            catch (Exception Desc)
            {
                CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
                return false;
            }
        }

        public bool InitHomeParameter()
        {
            try
            {
                // HClrTim : HomeClear Time : 원점 검색 Encoder 값 Set하기 위한 대기시간
                // HmDir(홈 방향): DIR_CCW (0) -방향 , DIR_CW(1) +방향
                // HOffset - 원점검출후 이동거리.
                // uZphas: 1차 원점검색 완료 후 엔코더 Z상 검출 유무 설정  0: 사용안함 , 1: Hmdir과 반대 방향, 2: Hmdir과 같은 방향
                // HmSig : PosEndLimit(0) -> +Limit
                //         NegEndLimit(1) -> -Limit
                //         HomeSensor (4) -> 원점센서(범용 입력 0)

                uint duRetCode = 0;
                double dVelFirst, dVelSecond, dVelThird, dVelLast, dAccFirst, dAccSecond;

                // 각각의 Edit 콘트롤에서 설정값을 가져옴
                dVelFirst = 40000.0D;
                dVelSecond = 4000.0D;
                dVelThird = 40.0D;
                dVelLast = 5.0D;
                dAccFirst = 0.5D;
                dAccSecond = 0.5D;

                switch (m_nAxisNo)
                {
                    case 2:
                        CAXM.AxmHomeSetMethod(m_nAxisNo, 0, 1, 0, 0, 0);
                        duRetCode = CAXM.AxmHomeSetVel(m_nAxisNo, 20000, 1000, 100, 10, 1, 1);
                        break;
                    case 3:
                        CAXM.AxmHomeSetMethod(m_nAxisNo, 0, 1, 0, 0, 0);
                        duRetCode = CAXM.AxmHomeSetVel(m_nAxisNo, 20000, 5000, 500, 20, 1, 1);
                        break;
                    default:
                        duRetCode = CAXM.AxmHomeSetVel(m_nAxisNo, dVelFirst * 1.5D, dVelSecond * 1.5D, dVelThird * 1.5D, dVelLast, dAccFirst, dAccSecond);
                        break;
                }
                
                if (duRetCode != (uint)AXT_FUNC_RESULT.AXT_RT_SUCCESS)
                {
                    CUtil.ShowMessageBox("ERROR", "FAILED HOME");
                }

                //CAXM.AxmHomeSetMethod(m_nAxisNo, 0, duHomeSignal, duZphas, dHomeClrTime, dHomeOffset);

                return true;
            }
            catch (Exception Desc)
            {
                CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
                CUtil.ShowMessageBox("EXCEPTION", Desc.Message, FormMessageBox.MESSAGEBOX_TYPE.OK);
                return false;
            }
        }

        public bool ServoOnOff(bool bOn)
        {
            try
            {
                string strReason = "";
                uint uRet = 0;
                if (bOn)
                {
                    uRet = CAXM.AxmSignalServoOn(m_nAxisNo, 1);
                }
                else
                {
                    uRet = CAXM.AxmSignalServoOn(m_nAxisNo, 0);
                }
                if (uRet != 0)
                {
                    strReason = GetReturnCode(uRet);
                    CLogger.WriteLog(LOG.MOTION, "[Fail] --> {0}", strReason);
                    return false;
                }

                CLogger.WriteLog(LOG.MOTION, "[OK] {0}==>{1}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name);
                return true;
            }
            catch (Exception Desc)
            {
                CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
                CUtil.ShowMessageBox("EXCEPTION", Desc.Message, FormMessageBox.MESSAGEBOX_TYPE.OK);
                return false;
            }
        }

