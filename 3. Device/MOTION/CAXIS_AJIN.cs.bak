        /// <param name="nAxis">변경하고자 하는 축</param>
        /// <param name="dUint">거리</param>
        /// <param name="nPulse">펄스</param>
        /// <returns></returns>
        public bool SetUnitPerFulse(int nAxis, double dUint, int nPulse)
        {
            try
            {
                // 0축 지령 값을 mm단위로 변경하고자 할때 
                // nAxis == 0
                // dUint == 1000
                // nPulse == 1

                // 0축 지령 값을 Pulse단위로 변경하고자 할때 
                // nAxis == 0
                // dUint == 1
                // nPulse == 1

                string strReason = "";
                uint uRet = 0;
                uRet = CAXM.AxmMotSetMoveUnitPerPulse(nAxis, dUint, nPulse);

                if (uRet != 0)
                {
                    strReason = GetReturnCode(uRet);
                    CLogger.WriteLog(LOG.MOTION, "[Fail] --> {0}", strReason);
                    return false;
                }

                CLogger.WriteLog(LOG.MOTION, "[OK] {0}==>{1}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name);
                return true;
            }
            catch (Exception Desc)
            {
                CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
                return false;
            }
        }

