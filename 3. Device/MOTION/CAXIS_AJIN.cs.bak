        public bool Close()
        {
            try
            {
                StopThreadHome();
                StopThreadReadStatus();

                if (CAXL.AxlClose() != (uint)AXT_FUNC_RESULT.AXT_RT_SUCCESS)
                {
                    CLogger.WriteLog(LOG.ALARM, "Failed the Close the Axis [{0}]", AxisNo);
                    return false;
                }
                return true;
            }
            catch (Exception Desc)
            {
                CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
                return false;
            }
        }

        private string GetReturnCode(uint uFunctionNumber)
        {
            string strReason = "";
            try
            {
                if (uFunctionNumber != 0)
                {
                    switch (uFunctionNumber)
                    {
                        case 4053:
                            strReason = "해당 축 모션 초기화 실패";
                            break;
                        case 4101:
                            strReason = "해당 축이 존재하지 않음";
                            break;
                        case 1053:
                            strReason = "라이브러리 초기화 실패";
                            break;
                        default:
                            strReason = "정의 되지 않은 에러 코드";
                            break;
                    }

                    CLogger.WriteLog(LOG.ALARM, "MOTION ERROR : {0}", strReason);
                }
                return strReason;
            }
            catch (Exception Desc)
            {
                CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
                return strReason;
            }
        }

        private string GetStopCode(uint uFunctionNumber)
        {
            string strReason = "";
            try
            {
                //송현수 : 최선웅 선임 스탑 요청 시 나오는 코드에 따른 분기 / 알람 / 로그 추가
                if (uFunctionNumber != 0)
                {
                    switch (uFunctionNumber)
                    {
                        case 4053:
                            strReason = "해당 축 모션 초기화 실패";
                            break;
                        case 4101:
                            strReason = "해당 축이 존재하지 않음";
                            break;
                        case 1053:
                            strReason = "라이브러리 초기화 실패";
                            break;
                    }
                }
                return strReason;
            }
            catch (Exception Desc)
            {
                CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
                return strReason;
            }
        }

        #region Motion
        public bool Move(double dPosition)
        {
            try
            {
                if(!m_bIsHomeComplete)
                {
                    CUtil.ShowMessageBox("INTERLOCK", "The Axis Should Set Home First");
                    return false;
                }

                string strReason = "";
                uint uRet = 0;
                uRet = CAXM.AxmMoveStartPos(m_nAxisNo, dPosition, m_nMoveVelocity, 0.15, 0.2);

                if (uRet != 0)
                {
                    strReason = GetReturnCode(uRet);
                    CLogger.WriteLog(LOG.MOTION, "[Fail] --> {0}", strReason);
                    return false;
                }

                LAST_COMMAND_DESC = $"AXIS_{AxisName} => MOVE TO {dPosition.ToString("F2")}";
                LAST_COMMAND_PULSE = dPosition;

                CLogger.WriteLog(LOG.MOTION, LAST_COMMAND_DESC);
                
                return true;
            }
            catch (Exception Desc)
            {
                CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
                return false;
            }
        }

        public bool Wait(int nTimeOut = 10000)
        {
            try
            {
                long START_TIME = Environment.TickCount;

                while(true)
                {
                    Thread.Sleep(10);

                    if(Environment.TickCount - START_TIME > nTimeOut)
                    {
                        CLogger.WriteLog(LOG.ALARM, "AXIS {0} WAIT TIME OUT", AxisName);
                        break;
                    }

                    if (!Status.InMotion && Status.Inposition) return true;
                }

                return true;
            }
            catch (Exception Desc)
            {
                CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
                return false;
            }
        }

        public bool InpositionEx(double dPosition)
        {
            try
            {
                if (!m_bIsHomeComplete)
                {
                    CUtil.ShowMessageBox("INTERLOCK", "The Axis Should Set Home First");
                    return false;
                }

                if (dPosition >= ActualPos - (ActualPos * 0.05)
                    && dPosition <= ActualPos + (ActualPos * 0.05))
                {
                    // 커맨드 완료 로그 추가
                    CLogger.WriteLog(LOG.MOTION, $"Inposition Complete -> {AxisName} : TARGET : {dPosition} COMMAND : {Status.CommandPos}");
                    CLogger.WriteLog(LOG.MOTION, $"Inposition Complete -> {AxisName} : TARGET : {dPosition} ACTUAL  : {ActualPos}");
                    return true;
                }
                else
                {
                    // 커맨드 로그 추가
                    CLogger.WriteLog(LOG.MOTION, $"{AxisName} : TARGET : {dPosition} COMMAND : {Status.CommandPos}");
                    CLogger.WriteLog(LOG.MOTION, $"{AxisName} : TARGET : {dPosition} ACTUAL  : {Status.ActualPos}");

                    Thread.Sleep(100);
                }

                return false;
            }
            catch (Exception Desc)
            {
                CCLog.Error( "[FAILED] {0}/{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, Desc.Message);
                return false;
            }
        }

