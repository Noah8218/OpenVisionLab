        public static List<CSignal> Inputs { get; set; } = new List<CSignal>();
        public static List<CSignal> Outputs { get; set; } = new List<CSignal>();

        public bool Init()
        {
            try
            {
                // Address 범위 지정 필요합니다.
                #region INPUT
                INPUT_START_DEVICE_ADDRESS = 4000;
                INPUT_End_DEVICE_ADDRESS = 4100;

                OUTPUT_START_DEVICE_ADDRESS = 4000;
                OUTPUT_End_DEVICE_ADDRESS = 4100;

                //////////////////////////////////////////////////////////////////////////////////////////Input 예시 
                Inputs.Clear();
                Outputs.Clear();

                //DI_PLC_MODE = new CSignal("DO_PC_MODE", "D2001", DEV_TYPE.LW, 1);
                //DO_PC_MODE = new CSignal("DO_PC_MODE", "D2010", DEV_TYPE.LW, 1);

                DO_SOL_OnOff = new CSignal("DO_SOL_OnOff", "D2000", DEV_TYPE.LW,1);

                #endregion
                #region OUTPUT

                #endregion
                LoadConfig();                
                Binary = new MCProtocol.Mitsubishi.McProtocolTcp(HostIP, HostPort, MCProtocol.Mitsubishi.McFrame.MC3E);

                // plc에서 포트 설정을 따로 안해줬기 떄문에 SMPT 기본 포트로 연결
                // 수정
                Binary.PortNumber = 2001;
                if (PingTest())
                {
                    Binary.Open();

                    StartThreadRead();
                }
                else
                {
                    return false;
                }
                
                return true;
            }
            catch (Exception Desc)
            {
                CLOG.ABNORMAL($"[ERROR] {MethodBase.GetCurrentMethod().ReflectedType.Name}==>{MethodBase.GetCurrentMethod().Name} Ex ==> {Desc.Message}");
                return false;
            }
        }

        public bool PingTest()
        {
            Ping pingSender = new Ping();
            int nTimeout = 1000;
            // IP를 따로 빼야함

            // plc 서버 ip 필요
            // 하드코딩된 ip 전부 레시피로 빼기
            // 적용
            PingReply reply = pingSender.Send(HostIP, nTimeout);

            if (reply.Status == IPStatus.Success)
            {
                //Logger.WriteLog(LOG.Normal, "[OK] - {0}", "PLC Server Ping TEST");
                return true;
            }
            // IP를 따로 빼야함

            //Logger.WriteLog(LOG.AbNormal, "[Fail] - {0}", "PLC Server Ping TEST");
            return false;
        }

        public bool Close()
        {
            try
            {
                if (Binary != null)
                {
                    Binary.Close();
                }
            }
            catch (Exception Desc)
            {
                CLOG.ABNORMAL($"[ERROR] {MethodBase.GetCurrentMethod().ReflectedType.Name}==>{MethodBase.GetCurrentMethod().Name} Ex ==> {Desc.Message}");
                return false;
            }

            return true;
        }
