        public void SetAddress(string strIp, int nPort)
        {
            HostIP = strIp;
            HostPort = nPort;
            //ILogger.Add(LOG_TYPE.SYSTEM, $"[OK] {MethodBase.GetCurrentMethod().ReflectedType.Name}==>{MethodBase.GetCurrentMethod().Name}");
        }
        public void GetAddress(out string strIp, out int nPort)
        {
            strIp = HostIP;
            nPort = HostPort;
        }

        #region File Manager
        private string DeviceConfigPath = Application.StartupPath + "\\CONFIG\\DEVICE\\" + "PLC" + ".xml";

        private string m_XMLName = "PLCConfig";
        public void LoadConfig()
        {
            LoadDeviceConfig();
        }

        public bool LoadDeviceConfig()
        {
            try
            {
#if Side_1
                DeviceConfigPath = Application.StartupPath + "\\CONFIG\\DEVICE\\" + "PLC_Side1" + ".xml";
#endif


#if Side_2
                DeviceConfigPath = Application.StartupPath + "\\CONFIG\\DEVICE\\" + "PLC_Side2" + ".xml";
#endif
                if (File.Exists(DeviceConfigPath))   //  xml 파일 존재 유무 검사
                {
                    XmlTextReader xmlReader = new XmlTextReader(DeviceConfigPath);    //  xml 파일 열기

                    try { LoadDeviceConfigByXML(xmlReader); }
                    catch (Exception e) { xmlReader.Close(); }

                    xmlReader.Close();
                }
                else
                {
                    SaveDeviceConfig();
                    return false;
                }
            }
            catch (Exception Desc)
            {
                //CLogger.WriteLog(Desc.Message);
                return false;
            }
            return true;
        }


        public bool LoadDeviceConfigByXML(XmlReader xmlReader)
        {
            while (xmlReader.Read())
            {
                if (xmlReader.NodeType == XmlNodeType.Element)
                {
                    switch (xmlReader.Name)
                    {
                        case "HostIP":
                            if (!xmlReader.Read()) return false;
                            HostIP = xmlReader.Value;
                            break;
                        case "HostPort":
                            if (!xmlReader.Read()) return false;
                            HostPort = int.Parse(xmlReader.Value);
                            break;                   
                    }
                }
                else
                {
                    if (xmlReader.NodeType == XmlNodeType.EndElement) { if (xmlReader.Name == m_XMLName) break; }
                }
            }
            //CLogger.Add(LOG.NORMAL, "[SUCCESS] PLC Config Load");
            return true;
        }

        public void SaveConfig()
        {
            SaveDeviceConfig();
        }

        private bool SaveDeviceConfig()
        {
#if Side_1
            DeviceConfigPath = Application.StartupPath + "\\CONFIG\\DEVICE\\" + "PLC_Side1" + ".xml";
#endif


#if Side_2
            DeviceConfigPath = Application.StartupPath + "\\CONFIG\\DEVICE\\" + "PLC_Side2" + ".xml";
#endif

            XmlWriterSettings settings = new XmlWriterSettings();
            settings.Indent = true;
            settings.NewLineOnAttributes = true;
            settings.IndentChars = "\t";
            settings.NewLineChars = "\r\n";
            XmlWriter xmlWriter = XmlWriter.Create(DeviceConfigPath, settings);
            try
            {
                xmlWriter.WriteStartDocument();
                SaveDeviceConfigByXML(xmlWriter);
                xmlWriter.WriteEndDocument();
            }
            catch (Exception Desc)
            {
                CLOG.ABNORMAL( "[FAILED] PLC Config Save");
            }
            finally
            {
                xmlWriter.Flush();
                xmlWriter.Close();
            }

            //CLogger.Add(LOG.NORMAL, "[SUCCESS] PLC Config Save ==> {0}", DeviceConfigPath);
            return true;
        }

        private bool SaveDeviceConfigByXML(XmlWriter xmlWriter)
        {
            xmlWriter.WriteStartElement("Parameter");
            xmlWriter.WriteElementString("HostIP", HostIP);
            xmlWriter.WriteElementString("HostPort", HostPort.ToString());
            xmlWriter.WriteEndElement();

            return true;
        }
        #endregion
    }
}
