        private void btnSetRoi_LD_JT_Click(object sender, EventArgs e)
        {
            try
            {
                FormImageEditView FrmImageEdit = new FormImageEditView(Displays[cbLayerList.SelectedIndex].ImageView.Image, "TEMP");
                if (FrmImageEdit.ShowDialog() == DialogResult.OK)
                {
                    switch (cbROIMenu.SelectedItem.ToString())
                    {
                        case "TOP ROI":
                            Global.Data.PropertyVisionInsp.TOP_ROI = FrmImageEdit.SelectedRegion;
                            //lbInspParam_ROI.Text = Global.Data.PropertyVisionInsp.TOP_ROI.ToString();
                            break;
                        case "LEFT ROI":
                            Global.Data.Property_LineGuage_LEFT.CVROI = FrmImageEdit.SelectedRegion;
                            //lbInspParam_ROI.Text = Global.Data.Property_LineGuage_LEFT.CVROI.ToString();
                            propertyGrid_Parameter.SelectedObject = Global.Data.Property_LineGuage_LEFT;
                            break;
                        case "RIGHT ROI":
                            Global.Data.Property_LineGuage_RIGHT.CVROI = FrmImageEdit.SelectedRegion;
                            //lbInspParam_ROI.Text = Global.Data.Property_LineGuage_RIGHT.CVROI.ToString();
                            propertyGrid_Parameter.SelectedObject = Global.Data.Property_LineGuage_RIGHT;
                            break;
                    }
                    //propertyGrid_Parameter.SelectedObject = Global.Data.PRO;
                }
            }
            catch (Exception ex)
            {
                CLogger.Add(LOG.EXCEPTION, "[FAILED] {0}==>{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, ex.Message);
            }
        }

        private void trbThreshold_Scroll(object sender, ScrollEventArgs e)
        {
            try
            {
                if (CUtil.IsImageEmpty(ImageSource)) return;

                int nThreshold = trbThreshold.Value;
                lbThreshold.Text = nThreshold.ToString();

                using (Mat imageSrc = ImageSource.Clone())
                {
                    Displays[1].ImageView.ibSource.Image = CConverter.ToBitmap(imageSrc.Threshold(nThreshold, 255, ThresholdTypes.Binary));
                    Displays[1].Activate();
                }
            }
            catch (Exception ex)
            {
                CLogger.Add(LOG.EXCEPTION, "[FAILED] {0}==>{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, ex.Message);
            }
        }

        private void btnCameraSetting_Click(object sender, EventArgs e)
        {
            try
            {                
                int Gain = int.Parse(tbGain.Texts);
                int Exposure = int.Parse(tbExposure.Texts);
                Global.Device.CAMERAS[0].Property.GAIN = Gain;
                Global.Device.CAMERAS[0].Property.EXPOSURETIME_US = Exposure;
                Global.Device.CAMERAS[0].Property.SaveConfig();

                Global.Device.CAMERAS[0].SetGain(Gain);
                Global.Device.CAMERAS[0].SetExposure(Exposure);
            }
            catch (Exception ex)
            {
                CLogger.Add(LOG.EXCEPTION, "[FAILED] {0}==>{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, ex.Message);
            }
        }

