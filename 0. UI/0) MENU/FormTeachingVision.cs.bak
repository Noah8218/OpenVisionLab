        private void SaveParameter()
        {
            try
            {
                FormMessageBox SaveForm = new FormMessageBox("Save", "현재까지 설정된 값을 저장하시겠습니까?");
                if (SaveForm.ShowDialog() == DialogResult.OK)
                {
                    int nIndex = cbCamera.SelectedIndex;
                    Global.Device.CAMERAS[nIndex].Property.SaveConfig();
                    Global.Data.PropertyVisionInsp.SaveConfig(Global.Recipe.Name);
                    Global.Data.Property_LineGuage_LEFT.SaveConfig(Global.Recipe.Name);
                    Global.Data.Property_LineGuage_RIGHT.SaveConfig(Global.Recipe.Name);
                }
            }
            catch (Exception ex)
            {
                CLogger.Add(LOG.EXCEPTION, "[FAILED] {0}==>{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, ex.Message);
            }
        }

