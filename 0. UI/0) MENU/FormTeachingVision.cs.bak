                rdoLeftEdgePara.Checked = true;
                //cbParameterMenu.Items.Add("LEFT EDGE");
                //cbParameterMenu.Items.Add("RIGHT EDGE");
                //cbParameterMenu.SelectedIndex = 0;
            }
            catch (Exception exc)
            {
                MessageBox.Show(exc.Message, "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                return false;
            }
            return true;
        }

        private void InitCameraItem()
        {
            for (int i = 0; i < Global.Device.CAMERA_COUNT; i++)
            {
                cbCamera.Items.Add("Camera " + (i + 1));
            }
        }

        private void InitLayerDisplay()
        {
            this.dockPanel = new WeifenLuo.WinFormsUI.Docking.DockPanel();

            var theme = new VS2015DarkTheme();
            this.dockPanel.Theme = theme;
            this.dockPanel.Dock = System.Windows.Forms.DockStyle.Fill;
            this.dockPanel.DocumentStyle = DocumentStyle.DockingWindow;

            TeachingPanel.Controls.Add(this.dockPanel);
            Displays.Add(new FormLayerDisplay(null, 0, m_Displays, false, "Main"));
            CreateLayerDisplay(null, DEFINE.Threshold, false);
            ShowPanel();

            Displays[0].ImageView.ibSource.ImageChanged += IbSource_ImageChanged;
        }

        private void IbSource_ImageChanged(object sender, EventArgs e)
        {
            ImageSource = CConverter.ToMat((Bitmap)Displays[0].ImageView.ibSource.Image);
        }

        private void InitLayListItem()
        {
            cbLayerList.Items.Clear();

            for (int i = 0; i < Displays.Count; i++)
            {
                cbLayerList.Items.Add(Displays[i].Text);
            }

            if (cbLayerList.Items.Count > 0)
            {
                cbLayerList.SelectedItem = strSelecteItem;
            }
        }

        private void ClearLayerDisplay(string strTitle)
        {
            try
            {
                object _ob = new object();
                Invoke((MethodInvoker)delegate ()
                {
                    lock (_ob)
                    {
                        bool bIsLayer = false;
                        int nIsIndex = 0;
                        for (int i = 0; i < Displays.Count; i++)
                        {
                            if (Displays[i].Text == strTitle)
                            {
                                bIsLayer = true;
                                nIsIndex = i;
                            }
                        }

                        if (bIsLayer)
                        {
                            Displays[nIsIndex].Dispose();
                            Displays.RemoveAt(nIsIndex);
                        }
                    }
                });
            }
            catch (Exception ex)
            {
                CLogger.Add(LOG.ABNORMAL, "[FAILED] {0}==>{1}   Ex ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, ex.Message);
            }
        }

        private void CreateLayerDisplay(Bitmap ImageSource, string strTitle, bool bUseClose = true)
        {
            try
            {
                ClearLayerDisplay(strTitle);

                object _ob = new object();
                Invoke((MethodInvoker)delegate ()
                {
                    lock (_ob)
                    {
                        bool bIsLayer = false;
                        int nIsIndex = 0;
                        for (int i = 0; i < Displays.Count; i++)
                        {
                            if (Displays[i].Text == strTitle)
                            {
                                bIsLayer = true;
                                nIsIndex = i;
                            }
                        }

                        if (!bIsLayer)
                        {
                            Displays.Add(new FormLayerDisplay(ImageSource, Displays.Count, Displays, bUseClose, strTitle));
                            Displays[Displays.Count - 1].Show(this.dockPanel, DockState.Document);
                        }
                    }
                });

                InitLayListItem();
            }
            catch (Exception ex)
            {
                CLogger.Add(LOG.ABNORMAL, "[FAILED] {0}==>{1}   Ex ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, ex.Message);
            }

        }

        private void ShowPanel()
        {
            for (int i = Displays.Count - 1; i >= 0; i--) { Displays[i].Show(this.dockPanel, DockState.Document); }
        }


