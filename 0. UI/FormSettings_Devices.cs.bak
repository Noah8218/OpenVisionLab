        private void btnSaveCameraParam_Click(object sender, EventArgs e)
        {
            try
            {
                if(CUtil.ShowMessageBox("SAVE", "DO YOU WANT TO SAVE THE PARAMETER OF CAMERA", FormMessageBox.MESSAGEBOX_TYPE.OKCANCEL))
                {
                    for (int i = 0; i < Global.iDevice.CAMERAS.Count; i++)
                    {
                        Global.iDevice.CAMERAS[i].SaveConfig();
                        Global.iDevice.CAMERAS[i].Init(i);
                    }
                }
            }
            catch (Exception ex)
            {
                CLogger.Add(LOG.EXCEPTION, "[FAILED] {0}==>{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, ex.Message);
                CUtil.ShowMessageBox("EXCEPTION", ex.Message, FormMessageBox.MESSAGEBOX_TYPE.OK);
            }
        }

