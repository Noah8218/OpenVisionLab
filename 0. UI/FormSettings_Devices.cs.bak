        IGlobal Global = IGlobal.Instance;

        #region Event Register        
        public EventHandler<EventArgs> EventUpdateUi;
        #endregion
        public FormSettings_Devices()
        {
            InitializeComponent();

            try
            {
                string[] ComportList = CUtil.AvalibleComports();

                if (ComportList.Length > 0)
                {
                    cbPortName.Items.AddRange(ComportList);
                    cbPortName.SelectedIndex = 0;
                }

                if(cbBaudrate.Items.Count > 0) cbBaudrate.SelectedIndex = 0;

                else
                {
                    lbConnection.Text = "DISCONNECTED";
                    lbConnection.Style = MetroColorStyle.Silver;

                    //btnConnect.Text = "CONNECT";
                }

            }
            catch (Exception ex)
            {
                CLogger.Add(LOG.EXCEPTION, "[FAILED] {0}==>{1}   Execption ==> {2}", MethodBase.GetCurrentMethod().ReflectedType.Name, MethodBase.GetCurrentMethod().Name, ex.Message);                
            }
        }

        private void FormSettings_Device_Load(object sender, EventArgs e)
        {
            try
            {
                InitEvent();
                Global.iData.PropertyCamera_1.INDEX = 0;
                propertyGrid_Cam1.SelectedObject = Global.iData.PropertyCamera_1;
                Global.iData.PropertyCamera_2.INDEX = 1;
                propertyGrid_Cam2.SelectedObject = Global.iData.PropertyCamera_2;
                Global.iData.PropertyCamera_3.INDEX = 2;
                propertyGrid_Cam3.SelectedObject = Global.iData.PropertyCamera_3;
