<?xml version="1.0" encoding="utf-8"?>
<VisionPipeline>
  <Name>Pin_Feature_Contour</Name>
  <Steps>
    <Step>
      <Name>01 Pin Feature Binary</Name>
      <ToolType>Threshold</ToolType>
      <Enabled>true</Enabled>
      <InputLayer>Main</InputLayer>
      <OutputLayer>Pin_Binary</OutputLayer>
      <Parameters>
        <Parameter>
          <Key>Mode</Key>
          <Value>Threshold</Value>
        </Parameter>
        <Parameter>
          <Key>Threshold</Key>
          <Value>100</Value>
        </Parameter>
        <Parameter>
          <Key>MaxValue</Key>
          <Value>255</Value>
        </Parameter>
        <Parameter>
          <Key>ThresholdType</Key>
          <Value>BinaryInv</Value>
        </Parameter>
      </Parameters>
    </Step>
    <Step>
      <Name>02 Pin Feature Close</Name>
      <ToolType>Morphology</ToolType>
      <Enabled>true</Enabled>
      <InputLayer>Pin_Binary</InputLayer>
      <OutputLayer>Pin_Clean</OutputLayer>
      <Parameters>
        <Parameter>
          <Key>Shape</Key>
          <Value>Rect</Value>
        </Parameter>
        <Parameter>
          <Key>Operator</Key>
          <Value>Close</Value>
        </Parameter>
        <Parameter>
          <Key>KernelWidth</Key>
          <Value>3</Value>
        </Parameter>
        <Parameter>
          <Key>KernelHeight</Key>
          <Value>3</Value>
        </Parameter>
        <Parameter>
          <Key>Iterations</Key>
          <Value>1</Value>
        </Parameter>
      </Parameters>
    </Step>
    <Step>
      <Name>03 Pin Feature Contour</Name>
      <ToolType>Contour</ToolType>
      <Enabled>true</Enabled>
      <InputLayer>Pin_Clean</InputLayer>
      <OutputLayer>Pin_Contour</OutputLayer>
      <Parameters>
        <Parameter>
          <Key>Name</Key>
          <Value>Contour_PinFeature</Value>
        </Parameter>
        <Parameter>
          <Key>PIXELPERMM</Key>
          <Value>0.006</Value>
        </Parameter>
        <Parameter>
          <Key>USE_THRESHOLD</Key>
          <Value>false</Value>
        </Parameter>
        <Parameter>
          <Key>USE_ADAPTIVE_THRESHOLD</Key>
          <Value>false</Value>
        </Parameter>
        <Parameter>
          <Key>USE_BITWISENOT</Key>
          <Value>false</Value>
        </Parameter>
        <Parameter>
          <Key>USE_ROI</Key>
          <Value>false</Value>
        </Parameter>
        <Parameter>
          <Key>USE_MULTI_ROI</Key>
          <Value>false</Value>
        </Parameter>
        <Parameter>
          <Key>USE_DRAW_IMAGE</Key>
          <Value>false</Value>
        </Parameter>
        <Parameter>
          <Key>ApproximationModes</Key>
          <Value>ApproxSimple</Value>
        </Parameter>
        <Parameter>
          <Key>DetectMode</Key>
          <Value>List</Value>
        </Parameter>
        <Parameter>
          <Key>MIN_AREA</Key>
          <Value>20</Value>
        </Parameter>
        <Parameter>
          <Key>MAX_AREA</Key>
          <Value>5000</Value>
        </Parameter>
        <Parameter>
          <Key>ClrGridHtml</Key>
          <Value>#00ff00</Value>
        </Parameter>
        <Parameter>
          <Key>DrawThickness</Key>
          <Value>2</Value>
        </Parameter>
      </Parameters>
      <UseAcceptance>true</UseAcceptance>
      <ExpectedSuccess>true</ExpectedSuccess>
      <MaxElapsedMilliseconds>1000</MaxElapsedMilliseconds>
      <AcceptanceMetricName>ResultCount</AcceptanceMetricName>
      <UseAcceptanceMetricMinimum>true</UseAcceptanceMetricMinimum>
      <AcceptanceMetricMinimum>40</AcceptanceMetricMinimum>
      <UseAcceptanceMetricMaximum>true</UseAcceptanceMetricMaximum>
      <AcceptanceMetricMaximum>70</AcceptanceMetricMaximum>
    </Step>
  </Steps>
</VisionPipeline>
