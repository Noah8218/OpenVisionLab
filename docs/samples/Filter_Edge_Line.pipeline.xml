<?xml version="1.0" encoding="utf-8"?>
<VisionPipeline>
  <Name>Filter_Edge_Line</Name>
  <Steps>
    <Step>
      <Name>01 Smooth Image</Name>
      <ToolType>Filter</ToolType>
      <Enabled>true</Enabled>
      <InputLayer>Main</InputLayer>
      <OutputLayer>Filtered</OutputLayer>
      <Parameters>
        <Parameter>
          <Key>FilterType</Key>
          <Value>GaussianBlur</Value>
        </Parameter>
        <Parameter>
          <Key>KernelWidth</Key>
          <Value>5</Value>
        </Parameter>
        <Parameter>
          <Key>KernelHeight</Key>
          <Value>5</Value>
        </Parameter>
        <Parameter>
          <Key>BorderType</Key>
          <Value>Default</Value>
        </Parameter>
      </Parameters>
    </Step>
    <Step>
      <Name>02 Canny Edge</Name>
      <ToolType>EdgeDetection</ToolType>
      <Enabled>true</Enabled>
      <InputLayer>Filtered</InputLayer>
      <OutputLayer>Edge</OutputLayer>
      <Parameters>
        <Parameter>
          <Key>EdgeType</Key>
          <Value>Canny</Value>
        </Parameter>
        <Parameter>
          <Key>CannyThresholdLow</Key>
          <Value>80</Value>
        </Parameter>
        <Parameter>
          <Key>CannyThresholdHigh</Key>
          <Value>160</Value>
        </Parameter>
        <Parameter>
          <Key>CannyApertureSize</Key>
          <Value>3</Value>
        </Parameter>
        <Parameter>
          <Key>UseL2Gradient</Key>
          <Value>true</Value>
        </Parameter>
      </Parameters>
    </Step>
    <Step>
      <Name>03 Line Gauge</Name>
      <ToolType>LineGauge</ToolType>
      <Enabled>true</Enabled>
      <InputLayer>Edge</InputLayer>
      <OutputLayer>Line_Result</OutputLayer>
      <Parameters>
        <Parameter>
          <Key>Name</Key>
          <Value>LineGauge</Value>
        </Parameter>
        <Parameter>
          <Key>PIXELPERMM</Key>
          <Value>0.006</Value>
        </Parameter>
        <Parameter>
          <Key>CONTRAST</Key>
          <Value>30</Value>
        </Parameter>
        <Parameter>
          <Key>THICKNESS</Key>
          <Value>5</Value>
        </Parameter>
        <Parameter>
          <Key>SAMPLING_STEP</Key>
          <Value>10</Value>
        </Parameter>
        <Parameter>
          <Key>SHOW_FITLINE</Key>
          <Value>true</Value>
        </Parameter>
      </Parameters>
      <UseAcceptance>true</UseAcceptance>
      <ExpectedSuccess>true</ExpectedSuccess>
      <MaxElapsedMilliseconds>300</MaxElapsedMilliseconds>
    </Step>
  </Steps>
</VisionPipeline>
