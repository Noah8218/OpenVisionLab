<?xml version="1.0" encoding="utf-8"?>
<VisionPipeline>
  <Name>Threshold_Morphology_Contour</Name>
  <Steps>
    <Step>
      <Name>01 Binary Threshold</Name>
      <ToolType>Threshold</ToolType>
      <Enabled>true</Enabled>
      <InputLayer>Main</InputLayer>
      <OutputLayer>Binary</OutputLayer>
      <Parameters>
        <Parameter>
          <Key>Mode</Key>
          <Value>Threshold</Value>
        </Parameter>
        <Parameter>
          <Key>Threshold</Key>
          <Value>120</Value>
        </Parameter>
        <Parameter>
          <Key>MaxValue</Key>
          <Value>255</Value>
        </Parameter>
        <Parameter>
          <Key>ThresholdType</Key>
          <Value>Binary</Value>
        </Parameter>
      </Parameters>
    </Step>
    <Step>
      <Name>02 Noise Close</Name>
      <ToolType>Morphology</ToolType>
      <Enabled>true</Enabled>
      <InputLayer>Binary</InputLayer>
      <OutputLayer>Closed</OutputLayer>
      <Parameters>
        <Parameter>
          <Key>Shape</Key>
          <Value>Rect</Value>
        </Parameter>
        <Parameter>
          <Key>Operator</Key>
          <Value>Close</Value>
        </Parameter>
        <Parameter>
          <Key>KernelWidth</Key>
          <Value>5</Value>
        </Parameter>
        <Parameter>
          <Key>KernelHeight</Key>
          <Value>5</Value>
        </Parameter>
        <Parameter>
          <Key>Iterations</Key>
          <Value>1</Value>
        </Parameter>
      </Parameters>
    </Step>
    <Step>
      <Name>03 Contour Inspect</Name>
      <ToolType>Contour</ToolType>
      <Enabled>true</Enabled>
      <InputLayer>Closed</InputLayer>
      <OutputLayer>Contour_Result</OutputLayer>
      <Parameters>
        <Parameter>
          <Key>Name</Key>
          <Value>Contour</Value>
        </Parameter>
        <Parameter>
          <Key>PIXELPERMM</Key>
          <Value>0.006</Value>
        </Parameter>
        <Parameter>
          <Key>DetectMode</Key>
          <Value>List</Value>
        </Parameter>
        <Parameter>
          <Key>ApproximationModes</Key>
          <Value>ApproxSimple</Value>
        </Parameter>
        <Parameter>
          <Key>MIN_AREA</Key>
          <Value>100</Value>
        </Parameter>
        <Parameter>
          <Key>MAX_AREA</Key>
          <Value>1000000</Value>
        </Parameter>
        <Parameter>
          <Key>USE_ROI</Key>
          <Value>false</Value>
        </Parameter>
      </Parameters>
      <UseAcceptance>true</UseAcceptance>
      <ExpectedSuccess>true</ExpectedSuccess>
      <MaxElapsedMilliseconds>300</MaxElapsedMilliseconds>
      <AcceptanceMetricName>ResultCount</AcceptanceMetricName>
      <UseAcceptanceMetricMinimum>true</UseAcceptanceMetricMinimum>
      <AcceptanceMetricMinimum>1</AcceptanceMetricMinimum>
    </Step>
  </Steps>
</VisionPipeline>
