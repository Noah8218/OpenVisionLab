        // 테스트용

        private static void LabelOnOff(CSignal DO)
        {
            DO.Current = 1;
            Thread.Sleep(CGlobal.Inst.Data.SETTING.Labeler_OnTime);
            DO.Current = 0;
            Thread.Sleep(CGlobal.Inst.Data.SETTING.Labeler_OffTime);
        }

        private static void LabelResetOnOff(CSignal DO)
        {
            CGlobal.Inst.Device.DIO_BD.On(DO);
            Thread.Sleep(CGlobal.Inst.Data.SETTING.Labeler_RestOnTime);
            CGlobal.Inst.Device.DIO_BD.Off(DO);
            Thread.Sleep(CGlobal.Inst.Data.SETTING.Labeler_OffTime);
        }

