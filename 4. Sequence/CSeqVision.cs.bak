        #region Thread 라벨
        private static CThreadStatus ThreadStatusAttachLabel = new CThreadStatus();

        public static void StartThreadAttachLabel()
        {
            Thread t = new Thread(new ParameterizedThreadStart(ThreadAttachLabel));
            t.Start(ThreadStatusAttachLabel);
        }

        public static void ResetThreadAttachLabel()
        {
            ThreadStatusAttachLabel.End();
        }

        public static void StopThreadAttachLabel()
        {
            if (!ThreadStatusAttachLabel.IsExit())
            {
                ThreadStatusAttachLabel.Stop(100);
            }

            ResetThreadAttachLabel();
        }

        private static void ThreadAttachLabel(object ob)
        {
            CThreadStatus ThreadStatus = (CThreadStatus)ob;

            ThreadStatus.Start("Attach Label");
            CLOG.NORMAL("Attach Label");

            try
            {
                // 무한루프
                while (!ThreadStatus.IsExit())
                {
                    for(int i=0; i < CGlobal.Inst.Data.Attaches.Count; i++)
                    {
                        CheckAttachLabel(CGlobal.Inst.Data.Attaches[i]);
                    }                   
                    Thread.Sleep(1);
                }
                ThreadStatus.End();
            }
            catch (Exception Desc)
            {
                CLOG.ABNORMAL($"[FAILED] {MethodBase.GetCurrentMethod().ReflectedType.Name}==>{MethodBase.GetCurrentMethod().Name}   Execption ==> {Desc.Message}");
                ThreadStatus.End();
            }
        }

        private static void CheckAttachLabel(List<CAttatchLabelling> AttatchLabels)
        {
            try
            {
                if (AttatchLabels.Count == 0) { return; }
                int count = AttatchLabels.Count;
                for (int i = 0; i < count; i++)
                {
                    // 여기서 on / off 작업
                    var AttatchLabel = AttatchLabels[i];
                    if (AttatchLabel.IsAttachLabel) { continue; }

                    if (AttatchLabel.Total_Acq_DistPerMM < CGlobal.Inst.Data.Total_Dist_PerMM)
                    {
                        // CGlobal.Inst.Data.SETTING.Select_Labeler_No1이 변수들에 들어가 있는 번호로 
                        // 릴마다 라벨러를 지정해줌
                        // 라벨러는 1개만 쓸수도 3개를 쓸수도 있음
                        switch (AttatchLabel.Reel_Position)
                        {
                            case (int)DEFINE.REEL_NO.NO1:                                
                                StartAttachLabel(CGlobal.Inst.Data.SETTING.Select_Labeler_No1);
                                break;
                            case (int)DEFINE.REEL_NO.NO2:
                                StartAttachLabel(CGlobal.Inst.Data.SETTING.Select_Labeler_No2);
                                break;
                            case (int)DEFINE.REEL_NO.NO3:
                                StartAttachLabel(CGlobal.Inst.Data.SETTING.Select_Labeler_No3);
                                break;
                            case (int)DEFINE.REEL_NO.NO4:
                                StartAttachLabel(CGlobal.Inst.Data.SETTING.Select_Labeler_No4);
                                break;
                        }
                        AttatchLabel.Use_Labelling = false;
                        AttatchLabel.IsAttachLabel = true;
                        // 삭제된 라벨링 리스트.. 관리.. 고객 요청..
                        if(CGlobal.Inst.Data.Already_AttachedList.Count > 500)
                        {
                            CGlobal.Inst.Data.Already_AttachedList.RemoveRange(0, 400);
                        }
                        CGlobal.Inst.Data.Already_AttachedList.Add(AttatchLabel);

                        CsvSave(AttatchLabel);
                        // on off라벨링
                        // 데이터 삭제
                        if (EventLabelResult != null)
                        {
                            EventLabelResult(null, new LabelResultArgs(CGlobal.Inst.Data.Attaches, CGlobal.Inst.Data.Already_AttachedList));
                        }
                    }
                }
                lock(m_ob)
                {
                    if (AttatchLabels.Count != 0) { AttatchLabels.RemoveAll(x => x.Use_Labelling == false); }
                }
                
                // 라벨러 위치를 검사하지만 부착 위치 엔코더 대비 현재 생산 엔코더가 100? 정도 차이나면 그냥 부착 안하고 흘러 간거니까 
                // 해당 리스트 값은 삭제 하도록 한다. 그리고 로그(이력)을 남겨서 왜 엔코더 부착을 안했는지 검토해야함
            }
            catch (Exception Desc)
            {
                CLOG.ABNORMAL($"[FAILED] {MethodBase.GetCurrentMethod().ReflectedType.Name}==>{MethodBase.GetCurrentMethod().Name}   Execption ==> {Desc.Message}");
            }          
        }

        // 사용자가 검사중 파일을 열어버리면 예외가 나올수 있으니 예외처리 진행
        private static void CsvSave(CAttatchLabelling attach)
        {
            try
            {
                string strPath = Application.StartupPath + "\\DATA\\" + DateTime.Now.ToString("yyyy-MM-dd") + "_Label.csv";

                // 파일이 없다면 최초에 컬럼을 추가합니다.
                if (!File.Exists(strPath))
                {
                    string strHeader = "No,라벨 부착 위치[mm],라벨러 포지션,라벨 부착 유무,DateTime";

                    File.AppendAllText(strPath, strHeader + "\r\n", Encoding.UTF8);
                }


                StringBuilder sb = new StringBuilder();

                // 현재 csv ROW 개수를 가져옴
                int nLineCount = File.ReadAllLines(strPath).Length;
                sb.Append(string.Format("{0},", nLineCount));
                sb.Append(string.Format("{0},", attach.Total_Acq_DistPerMM));
                sb.Append(string.Format("{0},", attach.Reel_Position));
                sb.Append(string.Format("{0},", "부착완료"));
                sb.Append(string.Format("{0},", DateTime.Now.ToString("yyyy-MM-dd-HH:mm:ss")));
                File.AppendAllText(strPath, sb.ToString() + "\r\n", Encoding.UTF8);
            }
            catch (Exception Desc)
            {
                CLOG.ABNORMAL($"[FAILED] {MethodBase.GetCurrentMethod().ReflectedType.Name}==>{MethodBase.GetCurrentMethod().Name}   Execption ==> {Desc.Message}");
            }          
        }

        private static void StartAttachLabel(int No)
        {            
            switch (No)
            {
                case (int)DEFINE.REEL_NO.NO1:
                    if (!CGlobal.Inst.Data.SETTING.USE_Labeler_No1)
                    {
                        CLOG.NORMAL($"라벨러 미사용 No : {No}");
                        return;
                    }

                    LabelOnOff(CGlobal.Inst.Device.DIO_BD.DO_02_Label1_Start);
                    CLOG.IO($"On Label Start No 1");
                    break;
                case (int)DEFINE.REEL_NO.NO2:
                    if (!CGlobal.Inst.Data.SETTING.USE_Labeler_No2)
                    {
                        CLOG.NORMAL($"라벨러 미사용 No : {No}");
                        return;
                    }
                    LabelOnOff(CGlobal.Inst.Device.DIO_BD.DO_04_Label2_Start);
                    CLOG.IO($"On Label Start No 2");
                    break;
                case (int)DEFINE.REEL_NO.NO3:
                    if (!CGlobal.Inst.Data.SETTING.USE_Labeler_No3)
                    {
                        CLOG.NORMAL($"라벨러 미사용 No : {No}");
                        return;
                    }
                    LabelOnOff(CGlobal.Inst.Device.DIO_BD.DO_06_Label3_Start);
                    CLOG.IO($"On Label Start No 3");
                    break;
                case (int)DEFINE.REEL_NO.NO4:
                    if (!CGlobal.Inst.Data.SETTING.USE_Labeler_No4)
                    {
                        CLOG.NORMAL($"라벨러 미사용 No : {No}");
                        return;
                    }
                    LabelOnOff(CGlobal.Inst.Device.DIO_BD.DO_08_Label4_Start);
                    CLOG.IO($"On Label Start No 4");
                    break;
            }
        }

