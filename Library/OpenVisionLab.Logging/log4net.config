<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<configSections>
		<section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net" />
	</configSections>

	<log4net>		

		<!-- ... 기존 설정 ... -->

		<logger name="_log">
			<level value="ALL" />
			<appender-ref ref="file" />
		</logger>		
		<logger name="_logAbnormal">
			<level value="ALL" />
			<appender-ref ref="Abnormal" />
		</logger>
		<logger name="_logDebug">
			<level value="ALL" />
			<appender-ref ref="Debug" />
		</logger>
	
		<logger name="_logMemoryPool">
			<level value="ALL" />
			<appender-ref ref="MemoryPool" />
		</logger>

		<logger name="_logMain">
			<level value="ALL" />
			<appender-ref ref="Main" />
		</logger>
		<logger name="_logWorker">
			<level value="ALL" />
			<appender-ref ref="Worker" />
		</logger>
		<logger name="_logGrab">
			<level value="ALL" />
			<appender-ref ref="Grab" />
		</logger>

		<logger name="_logVision">
			<level value="ALL" />
			<appender-ref ref="Vision" />
		</logger>
		
		<logger name="_logNetwork">
			<level value="ALL" />
			<appender-ref ref="Network" />
		</logger>

		<logger name="_logDB">
			<level value="ALL" />
			<appender-ref ref="DB" />
		</logger>

		<logger name="_logInspect">
			<level value="ALL" />
			<appender-ref ref="Inspect" />
		</logger>

		<logger name="_logConfig">
			<level value="ALL" />
			<appender-ref ref="Config" />
		</logger>
		
				

		<appender name="file" type="log4net.Appender.RollingFileAppender">
			<file value="Log\\" />
			<!--<datepattern value="yyyy\\\\MM\\\\dd\\\\yyyy-MM-dd_'ALL.log'"/>-->
			<datepattern value="yyyy\\MM\\dd\\yyyy-MM-dd_'ALL.log'"/>
			<appendToFile value="true" />
			
			<rollingStyle value="Composite" />

			<maximumFileSize value="50MB" />
			<maxSizeRollBackups value="20" />

			<staticLogFileName value="false" />
			<preserveLogFileNameExtension value="true" />
			
			<layout type="log4net.Layout.PatternLayout">
				<conversionPattern value="[%date] %message%newline" />
			</layout>
		</appender>
		
		<appender name="Abnormal" type="log4net.Appender.RollingFileAppender">
			<file value="Log\\" />
			<datepattern value="yyyy\\\\MM\\\\dd\\\\yyyy-MM-dd_'Abnormal.log'"/>			
			<appendToFile value="true" />
			<rollingStyle value="Composite" />

			<maximumFileSize value="50MB" />
			<maxSizeRollBackups value="20" />

			<staticLogFileName value="false" />
			<preserveLogFileNameExtension value="true" />
			<layout type="log4net.Layout.PatternLayout">
				<conversionPattern value="[%date] %message%newline" />
			</layout>
		</appender>
		<appender name="Debug" type="log4net.Appender.RollingFileAppender">
			<file value="Log\\" />
			<datepattern value="yyyy\\\\MM\\\\dd\\\\yyyy-MM-dd_'Debug.log'"/>			
			<appendToFile value="true" />
			<rollingStyle value="Composite" />

			<maximumFileSize value="50MB" />
			<maxSizeRollBackups value="20" />

			<staticLogFileName value="false" />
			<preserveLogFileNameExtension value="true" />
			<layout type="log4net.Layout.PatternLayout">
				<conversionPattern value="[%date] %message%newline" />
			</layout>
		</appender>
		<appender name="MemoryPool" type="log4net.Appender.RollingFileAppender">
			<file value="Log\\" />
			<datepattern value="yyyy\\\\MM\\\\dd\\\\yyyy-MM-dd_'MemoryPool.log'"/>			
			<appendToFile value="true" />
			<rollingStyle value="Composite" />

			<maximumFileSize value="50MB" />
			<maxSizeRollBackups value="20" />

			<staticLogFileName value="false" />
			<preserveLogFileNameExtension value="true" />
			<layout type="log4net.Layout.PatternLayout">
				<conversionPattern value="[%date] %message%newline" />
			</layout>
		</appender>		

		<appender name="Main" type="log4net.Appender.RollingFileAppender">
			<file value="Log\\" />
			<datepattern value="yyyy\\\\MM\\\\dd\\\\yyyy-MM-dd_'Main.log'"/>			
			<appendToFile value="true" />
			<rollingStyle value="Composite" />

			<maximumFileSize value="50MB" />
			<maxSizeRollBackups value="20" />

			<staticLogFileName value="false" />
			<preserveLogFileNameExtension value="true" />
			<layout type="log4net.Layout.PatternLayout">
				<conversionPattern value="[%date] %message%newline" />
			</layout>
		</appender>

		<appender name="Worker" type="log4net.Appender.RollingFileAppender">
			<file value="Log\\" />
			<datepattern value="yyyy\\\\MM\\\\dd\\\\yyyy-MM-dd_'Worker.log'"/>			
			<appendToFile value="true" />
			<rollingStyle value="Composite" />

			<maximumFileSize value="50MB" />
			<maxSizeRollBackups value="20" />

			<staticLogFileName value="false" />
			<preserveLogFileNameExtension value="true" />
			<layout type="log4net.Layout.PatternLayout">
				<conversionPattern value="[%date] %message%newline" />
			</layout>
		</appender>

		<appender name="Grab" type="log4net.Appender.RollingFileAppender">
			<file value="Log\\" />
			<datepattern value="yyyy\\\\MM\\\\dd\\\\yyyy-MM-dd_'Grab.log'"/>			
			<appendToFile value="true" />
			<rollingStyle value="Composite" />

			<maximumFileSize value="50MB" />
			<maxSizeRollBackups value="20" />

			<staticLogFileName value="false" />
			<preserveLogFileNameExtension value="true" />
			<layout type="log4net.Layout.PatternLayout">
				<conversionPattern value="[%date] %message%newline" />
			</layout>
		</appender>

		<appender name="Vision" type="log4net.Appender.RollingFileAppender">
			<file value="Log\\" />
			<datepattern value="yyyy\\\\MM\\\\dd\\\\yyyy-MM-dd_'Vision.log'"/>			
			<appendToFile value="true" />
			<rollingStyle value="Composite" />

			<maximumFileSize value="50MB" />
			<maxSizeRollBackups value="20" />

			<staticLogFileName value="false" />
			<preserveLogFileNameExtension value="true" />
			<layout type="log4net.Layout.PatternLayout">
				<conversionPattern value="[%date] %message%newline" />
			</layout>
		</appender>
		

		<appender name="Network" type="log4net.Appender.RollingFileAppender">
			<file value="Log\\" />
			<datepattern value="yyyy\\\\MM\\\\dd\\\\yyyy-MM-dd_'Network.log'"/>
			<appendToFile value="true" />
			<rollingStyle value="Composite" />

			<maximumFileSize value="50MB" />
			<maxSizeRollBackups value="20" />

			<staticLogFileName value="false" />
			<preserveLogFileNameExtension value="true" />
			<layout type="log4net.Layout.PatternLayout">
				<conversionPattern value="[%date] %message%newline" />
			</layout>
		</appender>

		<appender name="DB" type="log4net.Appender.RollingFileAppender">
			<file value="Log\\" />
			<datepattern value="yyyy\\\\MM\\\\dd\\\\yyyy-MM-dd_'DB.log'"/>
			<appendToFile value="true" />
			<rollingStyle value="Composite" />

			<maximumFileSize value="50MB" />
			<maxSizeRollBackups value="20" />

			<staticLogFileName value="false" />
			<preserveLogFileNameExtension value="true" />
			<layout type="log4net.Layout.PatternLayout">
				<conversionPattern value="[%date] %message%newline" />
			</layout>
		</appender>

		<appender name="Inspect" type="log4net.Appender.RollingFileAppender">
			<file value="Log\\" />
			<datepattern value="yyyy\\\\MM\\\\dd\\\\yyyy-MM-dd_'Inspect.log'"/>
			<appendToFile value="true" />
			<rollingStyle value="Composite" />

			<maximumFileSize value="50MB" />
			<maxSizeRollBackups value="20" />

			<staticLogFileName value="false" />
			<preserveLogFileNameExtension value="true" />
			<layout type="log4net.Layout.PatternLayout">
				<conversionPattern value="[%date] %message%newline" />
			</layout>
		</appender>

		<appender name="Config" type="log4net.Appender.RollingFileAppender">
			<file value="Log\\" />
			<datepattern value="yyyy\\\\MM\\\\dd\\\\yyyy-MM-dd_'Config.log'"/>
			<appendToFile value="true" />
			<rollingStyle value="Composite" />

			<maximumFileSize value="50MB" />
			<maxSizeRollBackups value="20" />

			<staticLogFileName value="false" />
			<preserveLogFileNameExtension value="true" />
			<layout type="log4net.Layout.PatternLayout">
				<conversionPattern value="[%date] %message%newline" />
			</layout>
		</appender>		
		
		<appender name="fatal_file" type="log4net.Appender.RollingFileAppender">
			<file value="Log\\fatal.log" />
			<appendToFile value="true" />
						<rollingStyle value="Composite" />

			<maximumFileSize value="50MB" />
			<maxSizeRollBackups value="20" />

			<staticLogFileName value="false" />
			<preserveLogFileNameExtension value="true" />
			<filter type="log4net.Filter.LevelRangeFilter">
				<param name="LevelMin" value="FATAL" />
				<param name="LevelMax" value="FATAL" />
			</filter>
			<layout type="log4net.Layout.PatternLayout">
				<conversionPattern value="[%date{yyyy-MM-dd HH:mm:ss.fff}] %message%newline" />
			</layout>
		</appender>
	</log4net>

	<system.diagnostics>
		<trace autoflush="true">
			<listeners>
				<add
					name="textWriterTraceListener"
					type="System.Diagnostics.TextWriterTraceListener"
					initializeData="log4net_debug.txt" />
			</listeners>
		</trace>
	</system.diagnostics>
</configuration>